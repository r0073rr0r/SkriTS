{
  "name": "@r0073rr0r/skit-ts",
  "version": "1.0.0",
  "description": "TypeScript port of the Skrit Serbian slang text transformer (satrovacki, utrovacki, leetrovacki)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": ["serbian", "slang", "satrovacki", "utrovacki", "leet", "cipher", "text-transform"],
  "author": "Velimir Majstorov <majstorov@gmail.com>",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/r0073rr0r/SkriTS.git"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"]
  }
}
